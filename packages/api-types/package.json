{
  "name": "@mabhas19/api-types",
  "version": "0.1.0",
  "private": true,
  "description": "Contract-first TypeScript types generated from the Mabhas19 API OpenAPI document.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "openapi-typescript ./openapi.json -o ./src/schema.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "openapi-typescript": "^7",
    "typescript": "^5"
  }
}
