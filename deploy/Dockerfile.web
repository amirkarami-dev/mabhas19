# Mabhas19 Web (Next.js 16) — build context is the repository ROOT (monorepo).
# Consumes the @mabhas19/assessment-core workspace package; next.config sets
# `output: "standalone"` + `outputFileTracingRoot` to the repo root, so the
# standalone server entry lands at web/server.js.
FROM node:24-alpine AS deps
WORKDIR /app
# Workspace manifests + lockfile first (better layer caching). mobile/package.json
# is needed so npm can resolve the workspace graph, but it is NOT installed.
COPY package.json package-lock.json ./
COPY packages/assessment-core/package.json packages/assessment-core/package.json
COPY web/package.json web/package.json
COPY mobile/package.json mobile/package.json
# Install only the web app + the shared package (skip the heavy Expo workspace).
RUN npm ci -w web -w packages/assessment-core

FROM node:24-alpine AS build
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages/assessment-core/node_modules ./packages/assessment-core/node_modules
COPY package.json package-lock.json ./
COPY packages/assessment-core/ ./packages/assessment-core/
COPY web/ ./web/
ENV NEXT_TELEMETRY_DISABLED=1
# Public API base is baked at build time for NEXT_PUBLIC_* vars.
ARG NEXT_PUBLIC_API_BASE=https://api.mabhas19.myceo.ir
ENV NEXT_PUBLIC_API_BASE=$NEXT_PUBLIC_API_BASE
RUN npm run build -w web

FROM node:24-alpine AS final
WORKDIR /app
ENV NODE_ENV=production NEXT_TELEMETRY_DISABLED=1 PORT=3000
# Standalone output (monorepo layout): server.js + node_modules under web/.
COPY --from=build /app/web/.next/standalone ./
COPY --from=build /app/web/.next/static ./web/.next/static
COPY --from=build /app/web/public ./web/public
EXPOSE 3000
CMD ["node", "web/server.js"]
