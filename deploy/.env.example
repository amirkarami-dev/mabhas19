# Copy to deploy/.env and adjust. Used by docker-compose.yml.

# --- Domains (set Arvancloud A records to 10.249.52.216) ---
WEB_DOMAIN=mabhas19.myceo.ir
API_DOMAIN=api.mabhas19.myceo.ir
MINIO_DOMAIN=s3.mabhas19.myceo.ir
MINIO_CONSOLE_DOMAIN=minio.mabhas19.myceo.ir
# NOTE: auth.myceo.ir (not auth.mabhas19.myceo.ir) — DNS A record is already set on the server.
AUTH_DOMAIN=auth.myceo.ir

# --- TLS (Let's Encrypt) ---
ACME_EMAIL=admin@myceo.ir

# --- PostgreSQL ---
POSTGRES_USER=mabhas19
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=Mabhas19Db

# --- MinIO (S3) ---
MINIO_ROOT_USER=mabhas19admin
MINIO_ROOT_PASSWORD=change-me-strong
MINIO_BUCKET=mabhas19

# --- SMS / OTP (Iranian provider Kavenegar; leave Provider=log to disable) ---
SMS_PROVIDER=log
SMS_API_KEY=
SMS_SENDER=
SMS_RELAY_TOKEN=

# --- Google sign-in (OAuth Web client id) ---
GOOGLE_CLIENT_ID=

# --- Admin user (seeded by both the API and the IdP on first startup) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- OpenIddict IdP (auth.myceo.ir) ---
# Password protecting the PFX signing certificate at deploy/certs/openiddict.pfx.
OPENIDDICT_CERT_PASSWORD=
# Shared secrets for OIDC confidential clients.
MABHAS19_WEB_CLIENT_SECRET=
PLAN_WEB_CLIENT_SECRET=
# Web Auth.js (NextAuth v5) session-encryption secret (the web container). AUTH_MABHAS19_SECRET
# (set in compose) must equal MABHAS19_WEB_CLIENT_SECRET above.
AUTH_SECRET=

# --- External import: Building Engineering System Organization (نظام مهندسی ساختمان) ---
NEZAM_BASE_URL=
NEZAM_API_KEY=
