# Internal dev roadmap/status board (status.myceo.ir) — PURE static, no build step.
# Just the three files in roadmap/ served by nginx. Access is gated by a Traefik
# basic-auth middleware (see the `status` service in docker-compose.newserver.yml).
# Build context is the repo root (context: .. in compose).
FROM nginx:1.27-alpine
COPY deploy/nginx.status.conf /etc/nginx/conf.d/default.conf
COPY roadmap/ /usr/share/nginx/html/
EXPOSE 80
