# Build-time flag (loaded by the Expo CLI). In this npm-workspaces monorepo, react
# is hoisted to the repo root; without this, Metro/export:embed uses the workspace
# root as the project root and the release JS bundle fails to resolve the entry.
# Keeping the project root = mobile/ (with nodeModulesPaths covering the hoisted
# deps) is what makes the release APK bundle correctly.
EXPO_NO_METRO_WORKSPACE_ROOT=1
