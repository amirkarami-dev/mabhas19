# landing-panel — build-time config (Vite inlines every VITE_* into dist/).
# PUBLIC values only: a static SPA bundle has no server side, so real secrets never belong here.

# Backend API (all CMS routes live under ${VITE_API_BASE}/api/kurdnezam).
VITE_API_BASE=http://localhost:5000

# Central OIDC IdP (OpenIddict). Dev runs `dotnet run --project src/Auth` on :5100.
VITE_AUTH_ISSUER=http://localhost:5100

# Public PKCE client registered on the IdP for this panel.
VITE_OIDC_CLIENT_ID=landing-panel

# Optional — defaults to "openid profile email roles mabhas19.api".
VITE_AUTH_SCOPE=openid profile email roles mabhas19.api
