# Base URL of the Mabhas19 .NET backend API.
# Dev default:
NEXT_PUBLIC_API_BASE=http://localhost:5000
# Production:
# NEXT_PUBLIC_API_BASE=https://api.mabhas19.myceo.ir

# Auth.js (NextAuth v5) — OIDC client for the central IdP (auth.myceo.ir).
# Generate AUTH_SECRET with: openssl rand -base64 33
AUTH_SECRET=
AUTH_MABHAS19_ISSUER=
AUTH_MABHAS19_ID=
AUTH_MABHAS19_SECRET=

# Public IdP base URL used client-side for the post-logout redirect.
# Must match the issuer (e.g. https://auth.myceo.ir).
NEXT_PUBLIC_AUTH_ISSUER=
