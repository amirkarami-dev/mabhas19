@page
@model Mabhas19.Auth.Pages.Account.EngineerLoginModel
@{
    ViewData["Title"] = "ورود مهندسین";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<h1>سامانه رفاهی مهندسین</h1>
@if (!Model.CodeSent)
{
    <p class="subtitle">کد ملی خود را وارد کنید؛ کد ورود به شماره موبایل ثبت‌شده در سازمان پیامک می‌شود.</p>
}
else
{
    <p class="subtitle">کد ۵ رقمی ارسال‌شده به <strong dir="ltr">@Model.MaskedPhone</strong> را وارد کنید.</p>
}

@if (Model.ErrorMessage is not null)
{
    <div class="error" role="alert">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span>@Model.ErrorMessage</span>
    </div>
}

@if (!Model.CodeSent)
{
    <form method="post" asp-page-handler="Request">
        <input type="hidden" name="returnUrl" value="@returnUrl" />
        <label for="NationalCode">کد ملی</label>
        <input asp-for="NationalCode" type="text" id="NationalCode" inputmode="numeric" maxlength="10"
               placeholder="__________ (۱۰ رقم)" autocomplete="off" autofocus />
        <button type="submit">ارسال کد ورود</button>
    </form>
}
else
{
    <form method="post" asp-page-handler="Verify">
        <input type="hidden" name="returnUrl" value="@returnUrl" />
        <input type="hidden" asp-for="NationalCode" />
        <label for="Code">کد تأیید</label>
        <input asp-for="Code" type="text" id="Code" class="otp-code" inputmode="numeric" maxlength="6"
               autocomplete="one-time-code" placeholder="—————" autofocus />
        <button type="submit">تأیید و ورود</button>
    </form>
}
