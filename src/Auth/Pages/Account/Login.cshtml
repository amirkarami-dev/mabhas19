@page
@model Mabhas19.Auth.Pages.Account.LoginModel
@{
    ViewData["Title"] = "ورود";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var otpHref = "/Account/Otp" + (returnUrl is not null ? "?returnUrl=" + Uri.EscapeDataString(returnUrl) : "");
}

<h1>ورود به حساب کاربری</h1>
<p class="subtitle">برای دسترسی به سامانه، نام کاربری و رمز عبور خود را وارد کنید.</p>

@if (Model.ErrorMessage is not null)
{
    <div class="error" role="alert">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span>@Model.ErrorMessage</span>
    </div>
}

<form method="post">
    <input type="hidden" name="returnUrl" value="@returnUrl" />
    <label for="UserName">نام کاربری</label>
    <input asp-for="UserName" type="text" id="UserName" autocomplete="username" placeholder="نام کاربری یا ایمیل" />
    <label for="Password">رمز عبور</label>
    <div class="pw-field">
        <input asp-for="Password" type="password" id="Password" autocomplete="current-password" placeholder="••••••••" />
        <button type="button" class="pw-toggle" id="pwToggle" data-shown="false" aria-pressed="false" aria-label="نمایش رمز عبور" title="نمایش رمز عبور">
            <svg class="eye-on" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M2.5 12S6 5.5 12 5.5 21.5 12 21.5 12 18 18.5 12 18.5 2.5 12 2.5 12Z" />
                <circle cx="12" cy="12" r="3" />
            </svg>
            <svg class="eye-off" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M10.7 6.1A7.9 7.9 0 0 1 12 6c6 0 9.5 6 9.5 6a15.4 15.4 0 0 1-3.2 3.8M6.5 8.2A15.2 15.2 0 0 0 2.5 12S6 18 12 18a8.7 8.7 0 0 0 3.5-.7" />
                <line x1="3" y1="3" x2="21" y2="21" />
            </svg>
        </button>
    </div>
    <button type="submit">ورود</button>
</form>

<script>
    // Show/hide the password. type="button" so it never submits the form.
    (function () {
        var input = document.getElementById('Password');
        var btn = document.getElementById('pwToggle');
        if (!input || !btn) return;
        btn.addEventListener('click', function () {
            var show = input.type === 'password';
            input.type = show ? 'text' : 'password';
            btn.dataset.shown = show ? 'true' : 'false';
            btn.setAttribute('aria-pressed', show ? 'true' : 'false');
            var label = show ? 'پنهان کردن رمز عبور' : 'نمایش رمز عبور';
            btn.setAttribute('aria-label', label);
            btn.setAttribute('title', label);
            input.focus();
        });
    })();
</script>

<a class="alt-btn" href="@otpHref">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2.5"/><line x1="12" y1="18" x2="12" y2="18"/></svg>
    ورود با کد یکبار مصرف (پیامک)
</a>

@if (!string.IsNullOrWhiteSpace(Model.GoogleClientId))
{
    <div class="divider">یا</div>
    <div id="g_id_onload"
         data-client_id="@Model.GoogleClientId"
         data-callback="handleGoogleCredential"
         data-auto_prompt="false">
    </div>
    <div class="g_id_signin" data-type="standard" data-theme="outline" data-size="large" data-text="signin_with" data-locale="fa"></div>

    <form method="post" asp-page-handler="Google" id="googleForm">
        <input type="hidden" name="returnUrl" value="@returnUrl" />
        <input type="hidden" name="credential" id="googleCredential" />
    </form>

    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <script>
        function handleGoogleCredential(response) {
            document.getElementById('googleCredential').value = response.credential;
            document.getElementById('googleForm').submit();
        }
    </script>
}
