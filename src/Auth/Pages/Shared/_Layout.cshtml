<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - مبحث ۱۹</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body {
            font-family: Tahoma, Arial, sans-serif;
            background: #f5f5f5;
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        .card {
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 2px 12px rgba(0,0,0,.1);
            padding: 2rem;
            width: 100%;
            max-width: 400px;
        }
        h1 { font-size: 1.4rem; margin-bottom: 1.2rem; text-align: center; color: #1a5c38; }
        label { display: block; margin-bottom: .25rem; font-size: .9rem; color: #444; }
        input[type=text], input[type=password], input[type=tel] {
            width: 100%;
            padding: .55rem .75rem;
            border: 1px solid #ccc;
            border-radius: 4px;
            font-size: 1rem;
            margin-bottom: .9rem;
            direction: ltr;
        }
        button[type=submit] {
            width: 100%;
            padding: .65rem;
            background: #1a5c38;
            color: #fff;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
        }
        button[type=submit]:hover { background: #145030; }
        .error { color: #c0392b; margin-bottom: .75rem; font-size: .9rem; }
        .link-row { text-align: center; margin-top: 1rem; font-size: .9rem; }
        .link-row a { color: #1a5c38; text-decoration: none; }
        .link-row a:hover { text-decoration: underline; }
        .divider { text-align: center; margin: 1rem 0; color: #888; font-size: .85rem; }
    </style>
</head>
<body>
    <div class="card">
        @RenderBody()
    </div>
</body>
</html>
