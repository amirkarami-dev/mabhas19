# Root .gitignore template — derived from the reference project (Mabhas19).
# Copy to the repository root as `.gitignore` (drop the `.template` suffix).
#
# Replace these <PLACEHOLDER> tokens:
#   <CORE_PACKAGE>  — the shared TS workspace package dir under packages/ (e.g. assessment-core)
#
# The two load-bearing, easy-to-miss rules are:
#   1. `**/[Pp]ackages/*` (a .NET/NuGet convention) would ALSO ignore the TypeScript
#      workspace package under /packages — so it is RE-INCLUDED explicitly below.
#   2. /mobile/android and /mobile/ios are generated by `expo prebuild` / EAS and are ignored.

## ── .NET ────────────────────────────────────────────────────────────────────
# Build results
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Ll]og/
[Ll]ogs/

# .NET / artifacts (build output is redirected here by Directory.Build.props)
project.lock.json
project.fragment.lock.json
artifacts/

# Visual Studio / Rider / VS Code
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
_ReSharper*/
*.[Rr]e[Ss]harper
*.sln.iml
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Test / coverage
[Tt]est[Rr]esult*/
TestResult.xml
nunit-*.xml
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml

# NuGet
*.nupkg
*.snupkg
# The packages folder can be ignored because of Package Restore (NuGet convention).
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# SQL Server / SQLite local files
*.mdf
*.ldf
*.ndf
*.db
*.db-shm
*.db-wal

# Misc .NET
*.pdb
*.binlog
healthchecksdb

## ── Node / web / mobile ──────────────────────────────────────────────────────
# Dependencies
node_modules/

# Next.js (web/)
web/.next/
web/out/
.next/
out/

# Expo / React Native generated native projects (regenerated by expo prebuild / EAS)
/mobile/android/
/mobile/ios/
.expo/

# Mobile build artifacts
*.apk
*.aab
*.ipa
*.zip

## ── Shared TypeScript workspace package ──────────────────────────────────────
# The NuGet rule `**/[Pp]ackages/*` above would otherwise ignore the shared TS package.
# Re-include its source, but NOT its node_modules.
!/packages/<CORE_PACKAGE>/
!/packages/<CORE_PACKAGE>/**
/packages/<CORE_PACKAGE>/node_modules/

## ── Secrets & environment ────────────────────────────────────────────────────
# Local env files (never commit real secrets)
.env
.env.*.local
*.env.local
.env.local
deploy/.env

# Certificates / keys
*.pfx
*.snk
*.publishsettings

# Local Claude Code settings (personal)
.claude/settings.local.json

## ── OS / editor noise ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
[Dd]esktop.ini
*~
*.swp
