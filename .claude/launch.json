{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "dev", "--", "-p", "3200"],
      "port": 3200,
      "autoPort": false
    },
    {
      "name": "analytics-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "analytics-web", "run", "dev", "--", "--port", "5273", "--strictPort"],
      "port": 5273,
      "autoPort": false
    },
    {
      "name": "roadmap",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8077", "--directory", "roadmap"],
      "port": 8077,
      "autoPort": false
    },
    {
      "name": "auth",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "src/Auth"],
      "port": 5100,
      "autoPort": false
    },
    {
      "name": "api",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "src/Web"],
      "port": 5000,
      "autoPort": false
    },
    {
      "name": "mun-sanandaj-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "mun-sanandaj-web", "run", "dev", "--", "--port", "5274", "--strictPort"],
      "port": 5274,
      "autoPort": false
    }
  ]
}
