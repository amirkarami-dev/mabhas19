{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "src/Web", "--launch-profile", "http"],
      "port": 5000,
      "autoPort": false
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "dev"],
      "port": 3000
    },
    {
      "name": "infra",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "-f", "deploy/docker-compose.dev.yml", "up", "minio"],
      "port": 9000,
      "autoPort": false
    }
  ]
}
